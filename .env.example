# ── Database ──────────────────────────────────────────────────────────────────
# Khi chạy Docker: dùng hostname "db" (tên service trong docker-compose)
# Khi dev local:   đổi thành localhost:5432
DATABASE_URL="postgresql://postgres:postgres@db:5432/linkhub"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# NEXTAUTH_URL = URL mà browser thực sự gõ vào (không phải Docker internal)
#
#   Local dev:               http://localhost:3000
#   VPS không có domain:     http://<VPS_IP>:<WEB_PORT>
#   VPS có domain (Nginx):   https://links.defikit.net   ← không cần port
#
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# ── Port ──────────────────────────────────────────────────────────────────────
# Port Docker expose ra ngoài host.
# Nếu dùng Nginx/Caddy reverse proxy thì đặt port bất kỳ (vd: 3100),
# Nginx sẽ forward từ 80/443 vào port này.
WEB_PORT=3000

# ── Admin account (tạo lần đầu khi seed) ──────────────────────────────────────
ADMIN_EMAIL="admin@defikit.net"
ADMIN_PASSWORD="admin123"
